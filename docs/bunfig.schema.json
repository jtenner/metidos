{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://metidos.local/schemas/bunfig.schema.json",
  "title": "Repository Bun configuration",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "serve": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "static": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "plugins": {
              "type": "array",
              "items": { "type": "string", "minLength": 1 },
              "uniqueItems": true
            }
          }
        }
      }
    }
  }
}
