# Copy this file to .env for local startup.
# Bun automatically loads .env for `bun run ...` commands.

# Browser-facing origin used by reverse-proxy TLS mode.
# Use the exact public origin the browser will load, for example:
#   https://metidos.example.com
#   https://metidos.example.com:8443
# The backend automatically adds this origin to the websocket allowlist.
METIDOS_PUBLIC_ORIGIN=https://your_computer_name

# Trust X-Forwarded-Host and X-Forwarded-Proto only when a trusted reverse
# proxy is the only public path to Bun and overwrites client-supplied headers.
# When set, forwarded origins are constrained to METIDOS_PUBLIC_ORIGIN plus any
# explicit METIDOS_ALLOWED_FORWARDED_ORIGINS entries.
# METIDOS_TRUST_PROXY=true
# METIDOS_ALLOWED_FORWARDED_ORIGINS=https://your_computer_name

# Optional extra browser origins when you need more than the public origin above.
# Comma-, space-, and newline-separated lists all work.
# METIDOS_ALLOWED_WS_ORIGINS=https://your_computer_name https://other-host.example

# Optional custom Bun loopback port.
# Nginx/Caddy should proxy to http://127.0.0.1:<this-port>.
# METIDOS_PORT=7599

# Optional static web-server share bind host. Only loopback hosts are accepted
# by default; wildcard addresses are treated as loopback. Setting a non-loopback
# host requires explicitly accepting public exposure risk.
# METIDOS_WEB_SERVER_SHARE_HOST=127.0.0.1
# METIDOS_WEB_SERVER_SHARE_ALLOW_PUBLIC_HOST=false

# Optional provider API keys. Prefer Plugin Settings for secrets that should be
# managed through Settings -> Plugins; use env vars when the process/container
# should own the credential.
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# ANTHROPIC_OAUTH_TOKEN=
# OPENROUTER_API_KEY=
# INCEPTION_API_KEY=
# XAI_API_KEY=
# ZAI_API_KEY=
# NVIDIA_API_KEY=
# GEMINI_API_KEY=
# GOOGLE_CLOUD_API_KEY=
# GOOGLE_CLOUD_PROJECT=
# GOOGLE_CLOUD_LOCATION=
# GROQ_API_KEY=
# KIMI_API_KEY=
# MINIMAX_API_KEY=
# MISTRAL_API_KEY=
# AZURE_OPENAI_API_KEY=
# AZURE_OPENAI_BASE_URL=
# AZURE_OPENAI_RESOURCE_NAME=
# AZURE_OPENAI_API_VERSION=
# AZURE_OPENAI_DEPLOYMENT_NAME_MAP=

# Optional Brave Search API key for fallback web_search on providers without
# native search support.
# BRAVE_SEARCH_API_KEY=your_brave_search_api_key

# Optional first-party utility plugin credentials. Declare and approve the
# matching plugin before relying on these values.
# NOTION_API_KEY=
# SERPAPI_API_KEY=
# GMAIL_CLIENT_ID=
# GMAIL_CLIENT_SECRET=
# TELEGRAM_BOT_TOKEN=
# UPLOADTHING_API_KEY=
# NTFY_TOPIC=
# NTFY_TOKEN=

# Optional OAuth/auth-file imports for Pi-owned providers. For containers,
# prefer read-only file mounts into the plugin .data paths documented in the
# installation skill.
# CODEX_AUTH_JSON_PATH=/absolute/path/to/codex/auth.json
# GITHUB_COPILOT_AUTH_JSON_PATH=/absolute/path/to/pi/auth.json

# Optional Ollama endpoint contract used when you want Metidos to bootstrap the
# provider from env instead of saving it in Settings. Local/private Ollama URLs
# require the Ollama plugin's unsafe approval plus this private-network allowlist.
# METIDOS_PLUGIN_UNSAFE_PRIVATE_NETWORK_PLUGINS=ollama
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_API_KEY=
