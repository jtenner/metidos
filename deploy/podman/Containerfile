FROM docker.io/oven/bun:1.3.14-debian

ARG NODE_VERSION=26.3.0
ARG INSTALL_CHROMIUM=false
ARG INSTALL_GH=false
ARG INSTALL_GO=false
ARG INSTALL_LATEX=false
ARG INSTALL_RUST=false
ARG INSTALL_MOONBIT=false
ARG INSTALL_WASM_TOOLS=false
ARG WASM_TOOLS_VERSION=1.251.0
ARG BINARYEN_VERSION=130
ARG MOONBIT_VERSION=latest
ARG WHY3_VERSION=1.8.2
ARG ALT_ERGO_VERSION=2.6.3

ENV HOME=/home/metidos
ENV OPAMROOT=/opt/opam
ENV OPAMSWITCH=moonbit-proof
ENV CARGO_HOME=/home/metidos/.cargo
ENV RUSTUP_HOME=/home/metidos/.rustup
ENV GOPATH=/home/metidos/go
ENV MOON_HOME=/opt/moonbit

RUN apt-get update \
  && DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends build-essential ca-certificates git openssh-client python3 ripgrep tini wget xz-utils \
  && if [ "$INSTALL_CHROMIUM" = "true" ]; then DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends chromium chromium-sandbox; fi \
  && if [ "$INSTALL_GH" = "true" ]; then DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends gh; fi \
  && if [ "$INSTALL_GO" = "true" ]; then DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends golang-go; fi \
  && if [ "$INSTALL_RUST" = "true" ]; then DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends rustup; fi \
  && if [ "$INSTALL_MOONBIT" = "true" ]; then DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends autoconf libgmp-dev m4 opam pkg-config z3 zlib1g-dev; fi \
  && if [ "$INSTALL_WASM_TOOLS" = "true" ]; then DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends emscripten; fi \
  && if [ "$INSTALL_LATEX" = "true" ]; then DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends latexmk poppler-utils texlive-fonts-extra texlive-fonts-recommended texlive-latex-base texlive-latex-extra texlive-latex-recommended texlive-pictures; fi \
  && rm -rf /var/lib/apt/lists/*

RUN set -eux; \
  arch="$(uname -m)"; \
  case "$arch" in \
    x86_64) node_arch="x64" ;; \
    aarch64|arm64) node_arch="arm64" ;; \
    *) echo "unsupported arch: $arch" >&2; exit 1 ;; \
  esac; \
  node_dir="node-v${NODE_VERSION}-linux-${node_arch}"; \
  tmp="$(mktemp -d)"; \
  trap 'rm -rf "$tmp"' EXIT; \
  wget -q -O "$tmp/${node_dir}.tar.xz" "https://nodejs.org/dist/v${NODE_VERSION}/${node_dir}.tar.xz"; \
  wget -q -O "$tmp/SHASUMS256.txt" "https://nodejs.org/dist/v${NODE_VERSION}/SHASUMS256.txt"; \
  grep " ${node_dir}.tar.xz\$" "$tmp/SHASUMS256.txt" > "$tmp/node.sha256"; \
  (cd "$tmp" && sha256sum -c node.sha256); \
  rm -rf /opt/node-current; \
  mkdir -p /opt/node-current; \
  tar -xJf "$tmp/${node_dir}.tar.xz" --strip-components=1 -C /opt/node-current; \
  chown -R root:root /opt/node-current; \
  ln -sf /opt/node-current/bin/node /usr/local/bin/node; \
  ln -sf /opt/node-current/bin/npm /usr/local/bin/npm; \
  ln -sf /opt/node-current/bin/npx /usr/local/bin/npx; \
  node --version; \
  npm --version

RUN set -eux; \
  if [ "$INSTALL_GO" != "true" ]; then echo "Skipping optional Go toolchain"; exit 0; fi; \
  go version; \
  go env GOPATH

RUN set -eux; \
  if [ "$INSTALL_RUST" != "true" ]; then echo "Skipping optional Rust toolchain"; exit 0; fi; \
  mkdir -p "$HOME"; \
  rustup toolchain install stable --profile minimal; \
  rustup default stable; \
  rustup target add wasm32-unknown-unknown wasm32-wasip1 wasm32-wasip2 wasm32v1-none wasm32-unknown-emscripten; \
  rustup --version; \
  rustc --version; \
  cargo --version; \
  rustup target list --installed

RUN set -eux; \
  if [ "$INSTALL_MOONBIT" != "true" ]; then echo "Skipping optional MoonBit/proof toolchain"; exit 0; fi; \
  mkdir -p "$HOME"; \
  opam init --bare --disable-sandboxing --yes; \
  opam switch create "$OPAMSWITCH" ocaml-base-compiler.5.1.1 --yes; \
  eval "$(opam env --switch="$OPAMSWITCH" --set-switch)"; \
  opam install --yes "why3.${WHY3_VERSION}" "alt-ergo.${ALT_ERGO_VERSION}"; \
  why3 config detect; \
  why3 --version; \
  alt-ergo --version

RUN set -eux; \
  if [ "$INSTALL_MOONBIT" != "true" ]; then echo "Skipping optional MoonBit toolchain"; exit 0; fi; \
  arch="$(uname -m)"; \
  case "$arch" in \
    x86_64) target="linux-x86_64" ;; \
    aarch64|arm64) target="linux-aarch64" ;; \
    *) echo "unsupported arch: $arch" >&2; exit 1 ;; \
  esac; \
  if [ "$MOONBIT_VERSION" = "latest" ]; then encoded_version="latest"; else encoded_version="$(printf '%s' "$MOONBIT_VERSION" | sed 's/+/%2B/g')"; fi; \
  tmp="$(mktemp -d)"; \
  trap 'rm -rf "$tmp"' EXIT; \
  mkdir -p "$MOON_HOME"; \
  wget -q -O "$tmp/moonbit.tar.gz" "https://cli.moonbitlang.com/binaries/${encoded_version}/moonbit-${target}.tar.gz"; \
  rm -rf "$MOON_HOME/bin" "$MOON_HOME/include" "$MOON_HOME/lib"; \
  tar -xzf "$tmp/moonbit.tar.gz" -C "$MOON_HOME"; \
  find "$MOON_HOME/bin" -maxdepth 1 -type f -exec chmod +x {} +; \
  chmod +x "$MOON_HOME/bin/internal/tcc"; \
  wget -q -O "$tmp/core.tar.gz" "https://cli.moonbitlang.com/cores/core-${encoded_version}.tar.gz"; \
  mkdir -p "$MOON_HOME/lib"; \
  rm -rf "$MOON_HOME/lib/core"; \
  tar -xzf "$tmp/core.tar.gz" -C "$MOON_HOME/lib"; \
  PATH="$MOON_HOME/bin:$PATH" moon -C "$MOON_HOME/lib/core" bundle --warn-list -a --all; \
  PATH="$MOON_HOME/bin:$PATH" moon -C "$MOON_HOME/lib/core" bundle --warn-list -a --target wasm-gc --quiet; \
  PATH="$MOON_HOME/bin:$PATH" moon version --all

RUN set -eux; \
  if [ "$INSTALL_WASM_TOOLS" != "true" ]; then echo "Skipping optional wasm-tools"; exit 0; fi; \
  arch="$(uname -m)"; \
  case "$arch" in \
    x86_64) asset="wasm-tools-${WASM_TOOLS_VERSION}-x86_64-linux.tar.gz" ;; \
    aarch64|arm64) asset="wasm-tools-${WASM_TOOLS_VERSION}-aarch64-linux.tar.gz" ;; \
    *) echo "unsupported arch: $arch" >&2; exit 1 ;; \
  esac; \
  tmp="$(mktemp -d)"; \
  trap 'rm -rf "$tmp"' EXIT; \
  wget -q -O "$tmp/wasm-tools.tar.gz" "https://github.com/bytecodealliance/wasm-tools/releases/download/v${WASM_TOOLS_VERSION}/${asset}"; \
  tar -xzf "$tmp/wasm-tools.tar.gz" -C "$tmp"; \
  install -m 0755 "$(find "$tmp" -maxdepth 3 -type f -name wasm-tools | head -n 1)" /usr/local/bin/wasm-tools; \
  mkdir -p "$CARGO_HOME/bin"; \
  ln -sf /usr/local/bin/wasm-tools "$CARGO_HOME/bin/wasm-tools"; \
  wasm-tools --version

RUN set -eux; \
  if [ "$INSTALL_WASM_TOOLS" != "true" ]; then echo "Skipping optional Binaryen tools"; exit 0; fi; \
  arch="$(uname -m)"; \
  case "$arch" in \
    x86_64) asset="binaryen-version_${BINARYEN_VERSION}-x86_64-linux.tar.gz" ;; \
    aarch64|arm64) asset="binaryen-version_${BINARYEN_VERSION}-aarch64-linux.tar.gz" ;; \
    *) echo "unsupported arch: $arch" >&2; exit 1 ;; \
  esac; \
  tmp="$(mktemp -d)"; \
  trap 'rm -rf "$tmp"' EXIT; \
  wget -q -O "$tmp/binaryen.tar.gz" "https://github.com/WebAssembly/binaryen/releases/download/version_${BINARYEN_VERSION}/${asset}"; \
  rm -rf "/opt/binaryen-version_${BINARYEN_VERSION}"; \
  tar -xzf "$tmp/binaryen.tar.gz" -C /opt; \
  for tool in "/opt/binaryen-version_${BINARYEN_VERSION}"/bin/*; do \
    ln -sf "$tool" "/usr/local/bin/$(basename "$tool")"; \
  done; \
  wasm-opt --version

WORKDIR /app

COPY package.json bun.lock* bunfig.toml ./
COPY patches ./patches
RUN bun install --frozen-lockfile

COPY . .
RUN bun run tailwind:build \
  && chmod +x /app/deploy/podman/entrypoint.sh

ENV METIDOS_APP_DATA_DIR=/data
ENV METIDOS_PORT=7599
ENV METIDOS_TRUST_PROXY=true
ENV METIDOS_WEB_SERVER_SHARE_HOST=127.0.0.1
ENV METIDOS_NODE_BINARY=/usr/local/bin/node
ENV BUN_CHROME_PATH=/usr/bin/chromium
ENV METIDOS_CHROME_DEBUG_PORT=9222
ENV METIDOS_CHROME_DEBUG_BACKEND_PORT=19222
ENV METIDOS_CHROME_DEBUG_USER_DATA_DIR=/data/chrome-debug
ENV CODEX_AUTH_JSON_PATH=/data/plugins/codex/.data/auth.json
ENV MOONBIT_BIN_DIR=/opt/moonbit/bin
ENV PATH=/opt/moonbit/bin:/home/metidos/.cargo/bin:/home/metidos/go/bin:/opt/opam/moonbit-proof/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin

RUN printf '%s\n' \
  'export OPAMROOT="${OPAMROOT:-/opt/opam}"' \
  'export OPAMSWITCH="${OPAMSWITCH:-moonbit-proof}"' \
  'if command -v opam >/dev/null 2>&1 && [ -d "$OPAMROOT/$OPAMSWITCH" ]; then' \
  '  eval "$(opam env --switch="$OPAMSWITCH" --set-switch)"' \
  'fi' \
  > /etc/profile.d/metidos-opam.sh

RUN printf '%s\n' \
  'if [ -n "${MOONBIT_BIN_DIR:-}" ] && [ -d "$MOONBIT_BIN_DIR" ]; then' \
  '  case ":$PATH:" in' \
  '    *":$MOONBIT_BIN_DIR:"*) ;;' \
  '    *) export PATH="$MOONBIT_BIN_DIR:$PATH" ;;' \
  '  esac' \
  'fi' \
  > /etc/profile.d/metidos-moonbit.sh

EXPOSE 7599 9222

ENTRYPOINT ["/usr/bin/tini", "--", "/app/deploy/podman/entrypoint.sh"]
