{
  "name": "getdown",
  "version": "0.0.0",
  "module": "index.ts",
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "react": "^19.2.6",
    "react-dom": "^19.2.7",
    "typescript": "^6.0.3"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "exports": {
    ".": {
      "types": "./src/index.tsx",
      "import": "./index.ts"
    }
  },
  "description": "React component API shell for GitHub Flavored Markdown.",
  "files": [
    "src",
    "index.ts",
    "README.md",
    "docs"
  ],
  "keywords": [
    "markdown",
    "gfm",
    "react",
    "typescript"
  ],
  "private": false,
  "scripts": {
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "perf:baseline": "bun run perf/baseline.tsx",
    "perf:baseline:json": "bun run perf/baseline.tsx --json",
    "perf:baseline:save": "bun run perf/baseline.tsx --save"
  },
  "type": "module",
  "types": "src/index.tsx"
}
