{
  "$schema": "https://biomejs.dev/schemas/2.5.0/schema.json",
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2
  },
  "assist": {
    "actions": {
      "source": {
        "organizeImports": "off"
      }
    }
  },
  "files": {
    "includes": [
      "**",
      "!**/coverage",
      "!**/dist",
      "!**/build",
      "!**/node_modules",
      "!**/.metidos-build",
      "!**/src/mainview/index.css"
    ]
  },
  "css": {
    "parser": {
      "tailwindDirectives": true
    }
  }
}
