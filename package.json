{
  "name": "metidos",
  "private": true,
  "type": "module",
  "version": "0.0.1",
  "packageManager": "bun@1.3.13",
  "scripts": {
    "tailwind:build": "tailwindcss -i ./src/mainview/input.css -o ./src/mainview/index.css --minify",
    "tailwind:watch": "tailwindcss -i ./src/mainview/input.css -o ./src/mainview/index.css --watch",
    "website:build": "tailwindcss -i ./website/input.css -o ./website/styles.css --minify",
    "website:watch": "tailwindcss -i ./website/input.css -o ./website/styles.css --watch",
    "sync:core-plugins": "bun run src/bun/sync-core-plugins.ts",
    "start": "bun run tailwind:build && bun run sync:core-plugins && bun run src/bun/start.ts",
    "start:telemetry": "bun run tailwind:build && bun run sync:core-plugins && bun run src/bun/start.ts --track-telemetry",
    "start:tls": "bun run tailwind:build && bun run sync:core-plugins && bun run src/bun/start.ts --tls",
    "start:tls:telemetry": "bun run tailwind:build && bun run sync:core-plugins && bun run src/bun/start.ts --tls --track-telemetry",
    "dev": "bun run tailwind:build && bun run sync:core-plugins && bun run src/bun/dev-supervisor.ts",
    "dev:watch": "bun run dev",
    "test": "bun run build:xmloxide-wasm && bun test --timeout 10000 --parallel=8",
    "test:build:prod-guards": "bun test src/bun/build-mainview.test.ts",
    "style:check": "bun run src/bun/mainview-style-enforcement.ts",
    "style:check:strict": "bun run src/bun/mainview-style-enforcement.ts --fail-on-violations",
    "a11y:check": "bun run src/bun/a11y-check.ts",
    "a11y:check:strict": "bun run src/bun/a11y-check.ts --strict",
    "setup:otp": "bun run .pi/skills/metidos-installation/setup-otp.js",
    "auth:reset": "bun run src/bun/auth/reset.ts",
    "audit:log": "bun run src/bun/security-audit-cli.ts",
    "harness:starvation": "bun run src/bun/starvation-harness.ts",
    "benchmark:metidos-tools": "bun run src/bun/metidos-tool-load-benchmark.ts",
    "build:sqlite-security-extension": "bun run native/sqlite-security-extension/build.ts",
    "build:xmloxide-wasm": "bun run native/xmloxide-wasm/build.ts",
    "test:sqlite-security-extension": "bun run native/sqlite-security-extension/build.ts --target=host --clean && bun run native/sqlite-security-extension/smoke-test.ts",
    "typecheck": "bunx tsgo --noEmit",
    "toml:format": "taplo fmt '**/*.toml' '.metidos/**/*.toml'",
    "toml:check": "taplo fmt --check '**/*.toml' '.metidos/**/*.toml' && taplo lint '**/*.toml' '.metidos/**/*.toml'",
    "toml:validate": "taplo lint '**/*.toml' '.metidos/**/*.toml'",
    "validate": "bunx biome check biome.json bun-plugin-react-compiler.ts src/bun src/mainview src/shared package.json tsconfig.json && bun run toml:check && bun run style:check && bun run typecheck && bun run test",
    "build:dev": "bun run tailwind:build && bun run src/bun/build-mainview.ts --dev",
    "build:prod": "bun run tailwind:build && bun run src/bun/build-mainview.ts --production",
    "ci:install": "bun install --frozen-lockfile",
    "format": "bunx biome format biome.json bun-plugin-react-compiler.ts src/bun src/mainview src/shared package.json tsconfig.json --write && bun run toml:format",
    "lint:fix": "bunx biome check biome.json bun-plugin-react-compiler.ts src/bun src/mainview src/shared package.json tsconfig.json --write && bun run toml:format",
    "lint:fix:unsafe": "bunx biome check biome.json bun-plugin-react-compiler.ts src/bun src/mainview src/shared package.json tsconfig.json --write --unsafe"
  },
  "dependencies": {
    "@floating-ui/react": "^0.27.19",
    "@mariozechner/pi-ai": "^0.73.1",
    "@mariozechner/pi-coding-agent": "^0.73.1",
    "@sinclair/typebox": "^0.34.49",
    "@tanstack/react-virtual": "^3.13.26",
    "@tootallnate/quickjs-emscripten": "0.23.0",
    "cronstrue": "^3.14.0",
    "ghostty-web": "^0.4.0",
    "ical.js": "^2.2.1",
    "node-gyp": "^12.3.0",
    "node-pty": "^1.1.0",
    "pyodide": "^0.29.4",
    "qrcode": "^1.5.4",
    "re2-wasm": "^1.0.2",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-shiki": "^0.10.1",
    "rrule": "^2.8.1",
    "turndown": "^7.2.4",
    "zod": "^4.4.3"
  },
  "overrides": {
    "@anthropic-ai/sdk": "0.91.1",
    "@hono/node-server": "1.19.14",
    "basic-ftp": "5.3.1",
    "brace-expansion": "5.0.6",
    "hono": "4.12.16",
    "protobufjs": "8.3.0",
    "ws": "8.20.1"
  },
  "devDependencies": {
    "@babel/core": "^7.29.7",
    "@biomejs/biome": "2.4.15",
    "@tailwindcss/cli": "^4.3.0",
    "@taplo/cli": "^0.7.0",
    "@types/babel__core": "^7.20.5",
    "@types/bun": "1.3.14",
    "@types/node": "^25.9.1",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@types/turndown": "5.0.6",
    "@typescript/native-preview": "7.0.0-dev.20260526.1",
    "ajv": "^8.20.0",
    "babel-plugin-react-compiler": "1.0.0",
    "tailwindcss": "^4.3.0"
  },
  "patchedDependencies": {
    "@mariozechner/pi-coding-agent@0.73.1": "patches/@mariozechner%2Fpi-coding-agent@0.73.1.patch"
  },
  "trustedDependencies": [
    "@google/genai",
    "@parcel/watcher",
    "node-pty",
    "protobufjs"
  ]
}
