METIDOS_PUBLIC_ORIGIN=https://your-device.your-tailnet.ts.net
METIDOS_HOST_PORT=7599
METIDOS_HOST_PROJECTS_DIR=/path/to/Projects
METIDOS_CONTAINER_PROJECTS_DIR=/home/metidos/Projects
METIDOS_CONTAINER_SOURCE_DIR=/app
METIDOS_INSTALL_DEPS_ON_START=1
NODE_VERSION=26.3.0

# Optional image toolchains. Leave false unless agents need the toolchain inside the container.
INSTALL_CHROMIUM=false
INSTALL_GH=false
INSTALL_GO=false
INSTALL_LATEX=false
INSTALL_RUST=false
INSTALL_MOONBIT=false
INSTALL_WASM_TOOLS=false
MOONBIT_VERSION=latest

# Set these only when INSTALL_CHROMIUM=true and browser automation is approved.
BUN_CHROME_PATH=
METIDOS_CHROME_DEBUG_PORT=
METIDOS_CHROME_DEBUG_BACKEND_PORT=19222
METIDOS_CHROME_DEBUG_USER_DATA_DIR=/data/chrome-debug
METIDOS_PLUGIN_UNSAFE_PRIVATE_NETWORK_PLUGINS=ollama
MOONBIT_BIN_DIR=/opt/moonbit/bin
CODEX_AUTH_JSON=/path/to/codex/auth.json
GITHUB_COPILOT_AUTH_JSON=/path/to/github-copilot/auth.json
METIDOS_HOST_SSH_DIR=/path/to/dedicated/deploy-key-ssh-dir

# Optional model provider and plugin API keys. Leave blank or remove unused keys.
AI_GATEWAY_API_KEY=
ANTHROPIC_API_KEY=
ANTHROPIC_OAUTH_TOKEN=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_API_VERSION=
AZURE_OPENAI_BASE_URL=
AZURE_OPENAI_DEPLOYMENT_NAME_MAP=
AZURE_OPENAI_RESOURCE_NAME=
BRAVE_SEARCH_API_KEY=
CEREBRAS_API_KEY=
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_KEY=
CLOUDFLARE_GATEWAY_ID=
DEEPSEEK_API_KEY=
FIREWORKS_API_KEY=
GCLOUD_PROJECT=
GEMINI_API_KEY=
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GOOGLE_CLOUD_API_KEY=
GOOGLE_CLOUD_LOCATION=
GOOGLE_CLOUD_PROJECT=
GROQ_API_KEY=
KIMI_API_KEY=
MINIMAX_API_KEY=
MINIMAX_CN_API_KEY=
MISTRAL_API_KEY=
MOONSHOT_API_KEY=
NOTION_API_KEY=
NTFY_TOKEN=
NTFY_TOPIC=
NVIDIA_API_KEY=
OLLAMA_API_KEY=
OLLAMA_BASE_URL=
INCEPTION_API_KEY=
OPENAI_API_KEY=
OPENCODE_API_KEY=
OPENROUTER_API_KEY=
SERPAPI_API_KEY=
TELEGRAM_BOT_TOKEN=
UPLOADTHING_API_KEY=
XAI_API_KEY=
ZAI_API_KEY=
